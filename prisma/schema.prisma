generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LifecycleStatus {
  ACTIVE
  ARCHIVED
}

model Project {
  id        String           @id @default(uuid())
  name      String           @unique
  client    String?
  color     String?
  status    LifecycleStatus  @default(ACTIVE)
  bookings  Booking[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
}

model Resource {
  id             String           @id @default(uuid())
  name           String           @unique
  role           String?
  team           String?
  capacity       Float            @default(37.5)
  status         LifecycleStatus  @default(ACTIVE)
  bookings       Booking[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
}

model Booking {
  id            String    @id @default(uuid())
  projectId     String
  resourceId    String
  weekStart     DateTime
  allocationPct Int
  note          String?

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resource      Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([resourceId, projectId, weekStart])
  @@index([weekStart])
  @@index([projectId, weekStart])
  @@index([resourceId, weekStart])
}

