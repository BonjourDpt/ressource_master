#!/usr/bin/env sh
# Append Assisted-by before the editor opens (and for -m / -F), unless already present.
#
# Value resolution (first match wins):
#   1) Env ASSISTED_BY (non-empty) for this commit only
#   2) Git config ressource.assistedBy (repo: git config …; or --global)
#   3) Cursor:unspecified  (generic IDE/assistant trailer — zero config)
#
# Human-only commits: git config ressource.assistedBy human-only
#   (session), or edit the line in the commit message, or unset for default.
# More specific AI label: git config ressource.assistedBy "Cursor:Composer-2"
#
# Args: $1 = path to commit message file, $2 = source (message|template|merge|squash|commit)

msg_file="$1"
source="${2:-}"

if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
  exit 0
fi

# Git supplies source=merge for merge commits; validator also skips Merge/Revert first line.
if [ "$source" = merge ]; then
  exit 0
fi

read -r first_line < "$msg_file" || first_line=""
# Strip CR for Windows-checked-out files
first_line=$(printf '%s' "$first_line" | tr -d '\r')
case "$first_line" in
  Merge\ *|Revert\ *) exit 0 ;;
esac

if grep -qiE '^Assisted-by:[[:space:]]*[^[:space:]]' "$msg_file"; then
  exit 0
fi

if [ -n "${ASSISTED_BY+x}" ] && [ -n "$ASSISTED_BY" ]; then
  value="$ASSISTED_BY"
else
  value=$(git config --get ressource.assistedBy 2>/dev/null) || true
  if [ -z "$value" ]; then
    value="Cursor:unspecified"
  fi
fi

printf '\nAssisted-by: %s\n' "$value" >> "$msg_file"
