# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Required (application) ---
# PostgreSQL connection string. Must be present for Prisma CLI and should match
# the database you migrate against (local, Neon, Supabase, etc.).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# --- Optional / reserved (not read by the app in v1) ---
# Uncomment and set when you add auth, APIs, or client-exposed config.
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=
# SOME_API_KEY=
# NEXT_PUBLIC_APP_URL=
